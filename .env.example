# Environment Variables for Entropy Prime

# ──────────────────────────────────────────────────────────────────────────────
# MongoDB Configuration
# ──────────────────────────────────────────────────────────────────────────────

# MongoDB Connection URL
# For MongoDB Atlas (Cloud): mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
# For Local MongoDB: mongodb://localhost:27017
MONGODB_URL=mongodb://admin:changeme@localhost:27017/entropy_prime?authSource=admin

# Database name
MONGODB_DB_NAME=entropy_prime

# ──────────────────────────────────────────────────────────────────────────────
# Backend Secrets (Auto-generated if not set)
# ──────────────────────────────────────────────────────────────────────────────

# HMAC key for real session tokens
EP_SESSION_SECRET=change_me_to_random_secret_key_32_chars_min

# CORS Allowed Origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://localhost:3001

# HMAC key for synthetic honeypot tokens (shadow mode)
EP_SHADOW_SECRET=change_me_to_random_shadow_secret_key

# ──────────────────────────────────────────────────────────────────────────────
# RL Model Configuration
# ──────────────────────────────────────────────────────────────────────────────

# Path to pre-trained DQN checkpoint (Governor)
EP_RL_CHECKPOINT=./checkpoints/governor.pt

# Path to Multi-Armed Bandit checkpoint
EP_MAB_CHECKPOINT=./checkpoints/mab.json

# Path to PPO checkpoint (Watchdog)
EP_PPO_CHECKPOINT=./checkpoints/watchdog.pt

# ──────────────────────────────────────────────────────────────────────────────
# Backend Server Configuration
# ──────────────────────────────────────────────────────────────────────────────

# Server host and port
HOST=0.0.0.0
PORT=8000

# Number of worker processes
WORKERS=4

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Debug mode
DEBUG=False

# CORS Allowed Origins (comma separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# ──────────────────────────────────────────────────────────────────────────────
# Frontend Configuration
# ──────────────────────────────────────────────────────────────────────────────

# API URL for frontend
VITE_API_URL=http://localhost:8000

# Frontend port (used by vite)
VITE_PORT=3000

